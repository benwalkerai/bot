# Inzen CLI Bot environment variables
# Copy this file and rename to .env (but never commit .env to git)
# Add your API keys below — only set the ones you need

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Groq (optional) — https://console.groq.com
# GROQ_API_KEY=your-api-key-here

# Ollama and llama.cpp don't need API keys
# Just make sure the server is running locally